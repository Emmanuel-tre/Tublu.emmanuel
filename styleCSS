@import "{{ site.theme }}";

/*  Style moderne */

body {
  font-family: 'Segoe UI', sans-serif;
}

h1, h2 {
  font-weight: 700;
}

section {
  margin-bottom: 40px;
}

/* cartes projet */
.project-card {
  background: #f5f5f5;
  padding: 20px;
  border-radius: 12px;
  margin-bottom: 20px;
  transition: 0.3s;
}

.project-card:hover {
  transform: translateY(-5px);
}
